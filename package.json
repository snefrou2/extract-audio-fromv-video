{
  "name": "audio-tools",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },

  "dependencies": {
    "fluent-ffmpeg": "^2.1.3"
  },

  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },

  "build": {

    "appId": "com.audio.tools",

    "productName": "AudioTools",

    "directories": {
      "output": "dist"
    },

    "files": [
      "**/*",
      "!node_modules/.cache",
      "ffmpeg/**/*"
    ],

    "win": {
      "target": "nsis"
    },

    "mac": {
      "target": "dmg"
    },

    "linux": {
      "target": "AppImage"
    }
  }
}